local function addPoint()
	if isPlaying or not rootPart then return end
	table.insert(recordedCFrames, rootPart.CFrame)

	local oldColor = recordBtn.BackgroundColor3
	recordBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
	task.delay(0.1, function() recordBtn.BackgroundColor3 = oldColor end)

	rebuildLines()
	updateUI()
end

-- Плавное сближение с точкой через Heartbeat + экспоненциальный Lerp,
-- в точности как в одиночном "how it should tp me" сниппете, но по цепочке точек.
local function moveToPoint(goal)
	local reached = false
	local con
	con = RunService.Heartbeat:Connect(function(dt)
		if not isPlaying or not rootPart.Parent then
			reached = true
			con:Disconnect()
			return
		end

		rootPart.CFrame = rootPart.CFrame:Lerp(goal, math.clamp(dt * currentLerpRate, 0, 1))

		if (rootPart.Position - goal.Position).Magnitude <= SNAP_DISTANCE then
			rootPart.CFrame = goal
			reached = true
			con:Disconnect()
		end
	end)

	while not reached do
		task.wait()
	end
end

local function playBackTweened()
	while isPlaying and #recordedCFrames > 0 do
		for _, targetCFrame in ipairs(recordedCFrames) do
			if not isPlaying then break end

			moveToPoint(targetCFrame)

			if not isPlaying then break end

			if pauseAtPoints and currentDelay > 0 then
				task.wait(currentDelay)
			end
		end

		if not isLooping then break end
	end
end

local function playBack()
	if #recordedCFrames == 0 then return end

	if isPlaying then
		-- Если уже играет, нажатие кнопки Старт/R работает как СТОП
		isPlaying = false
		return
	end

	if #recordedCFrames < 2 then
		-- Недостаточно точек для твина
		return
	end

	isPlaying = true
	updateUI()

	playBackTweened()

	isPlaying = false
	updateUI()
end

local function clearPoints()
	if isPlaying then return end
	table.clear(recordedCFrames)
	rebuildLines()
	updateUI()
end

