local function clearLines()
	for _, part in ipairs(linePartsList) do
		part:Destroy()
	end
	table.clear(linePartsList)
end

local function createLineSegment(p0, p1)
	local distance = (p1 - p0).Magnitude
	if distance < 0.01 then return end

	local part = Instance.new("Part")
	part.Name = "PathLine"
	part.Anchored = true
	part.CanCollide = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = Enum.Material.Neon
	part.Color = Color3.fromRGB(0, 170, 255)
	part.Size = Vector3.new(0.2, 0.2, distance)
	part.CFrame = CFrame.new(p0, p1) * CFrame.new(0, 0, -distance / 2)
	part.Parent = linesFolder

	table.insert(linePartsList, part)
end

local function rebuildLines()
	clearLines()
	if not linesEnabled then return end

	for i = 1, #recordedCFrames - 1 do
		createLineSegment(recordedCFrames[i].Position, recordedCFrames[i + 1].Position)
	end
end

